BOT_TOKEN=123456:telegram_bot_token
ADMIN_IDS=123456789
BOT_HTTP_PORT=8081
WEBHOOK_HOST=https://bot.local
WEBHOOK_PATH=/webhook
WEBHOOK_PORT=8081

# Источник кода бота, который будет собран в Dockerfile
BOT_REPO=https://github.com/WoodieDudy/wg-vpn-tg-bot.git
BOT_REF=main

WG_SERVER_INTERFACE=wg0
WG_SERVER_PORT=51820
WG_SERVER_SUBNET=10.66.0.0/24
WG_SERVER_ADDRESS=10.66.0.1/24
WG_SERVER_PRIVATE_KEY=replace_with_base64_private_key

WG_CLIENT_GATEWAY_IP=172.30.0.2
WG_CLIENT_EGRESS_IFACE=
WG_CLIENT_INTERFACE=wg-egress
WG_CLIENT_CONFIG_PATH=./config/wg-client/wg-egress.conf

# Traefik host rule for bot HTTP endpoint (if bot uses webhook/http server)
TRAEFIK_BOT_HOST=bot.local
